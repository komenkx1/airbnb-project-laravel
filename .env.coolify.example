# ======================================================
# COOLIFY ENVIRONMENT CONFIGURATION
# Copy this file to Coolify environment variables
# Do NOT commit .env with real values to git
# ======================================================

# Application
APP_NAME=Airbnb
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_KEY=base64:YOUR_GENERATED_KEY_HERE

# Database (Connect to Coolify MySQL Service)
DB_CONNECTION=mysql
DB_HOST=YOUR_MYSQL_SERVICE_HOST
DB_PORT=3306
DB_DATABASE=airbnb
DB_USERNAME=airbnb_user
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# Filesystem
FILESYSTEM_DISK=local

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Broadcasting
BROADCAST_DRIVER=log

# Mail (Configure if needed)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Vite (Production)
VITE_APP_NAME="${APP_NAME}"

# Other
MEMCACHED_HOST=127.0.0.1
